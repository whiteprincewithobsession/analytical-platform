# ==========================================
# Данные баз данных (БД и кэши)
# ==========================================
# PostgreSQL
postgres/pgdata/
postgres/pglogs/
postgres/backups/
postgres/wal/

# ClickHouse
clickhouse/clickhouse_data/
clickhouse/clickhouse_logs/
clickhouse/clickhouse_arch/

# Superset
supersetdb_data/
superset_home/

# Airflow
airflow/logs/
airflow/postgres/

# LocalStack
.localstack_data/
.localstack/

# ==========================================
# Python кэш и временные файлы
# ==========================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/

# pytest
.pytest_cache/
tests/.pytest_cache/
tests/htmlcov/
tests/.coverage
.coverage
.coverage.*
htmlcov/
*.cover

# ==========================================
# IDE и редакторы
# ==========================================
.idea/
.vscode/
*.swp
*.swo
*~

# ==========================================
# OS и временные файлы
# ==========================================
.DS_Store
Thumbs.db
*.tmp
*.log

# ==========================================
# Docker volumes (если не примонтированы)
# ==========================================
*.volume

# ==========================================
# Секреты и окружение
# ==========================================
.env
.env.local
.env.*.local
*.secret
*.key

# ==========================================
# Исключения (разрешаем конкретные файлы)
# ==========================================
# Оставляем архитектуру и документацию
!postgres/postgres_arch/
!clickhouse/clickhouse_arch/
!postgres/*.png
!postgres/*.md

# Оставляем инициализационные скрипты
!clickhouse/clickhouse-init/

# Оставляем конфигурацию
!postgres/config/
